{
  "name": "@clod_io/n8n-nodes-clod",
  "version": "0.1.0",
  "description": "n8n community node for CLōD API (OpenAI-compatible)",
  "keywords": [
    "n8n-community-node",
    "n8n-community-node-package",
    "n8n",
    "clod",
    "openai",
    "ai",
    "llm"
